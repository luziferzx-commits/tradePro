# MetaTrader 5 Connection Settings
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=Broker-Demo
# MT5_PATH="C:\Program Files\MetaTrader 5\terminal64.exe" # Optional: Path to MT5 executable

# Trading Configuration
SYMBOL=XAUUSD

# Safety and Execution Mode
DRY_RUN=True
ALLOW_LIVE_TRADING=False
IS_DEMO_ACCOUNT=True
MIN_EQUITY=100.0
SHADOW_MODE=False
REQUIRE_STOP_LOSS=True
REQUIRE_TAKE_PROFIT=True
MAX_OPEN_POSITIONS=1

# Risk Guards
RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_PCT=0.05
MAX_DRAWDOWN_PCT=0.15
MAX_CONSECUTIVE_LOSSES=5
MAX_SPREAD_POINTS=50
MAX_SLIPPAGE_POINTS=20
MAX_TRADES_PER_DAY=5

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Database
DATABASE_URL=sqlite:///trades.db

# AI Thresholds
AI_REVIEW_THRESHOLD=60
EXECUTION_THRESHOLD=75
MIN_AI_CONFIDENCE=80

# Startup Safety
# When True, a mismatch between the local ledger and broker positions at startup
# halts trading and trips the kill switch for manual review. Default False keeps
# the auto-sync-and-resume behaviour.
HALT_ON_RECONCILE_MISMATCH=False
# Optional: rolling P&L window (days) for the portfolio budget stats. 0 = today only.
GQOS_BUDGET_LOOKBACK_DAYS=0
