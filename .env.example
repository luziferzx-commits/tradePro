# MetaTrader 5 Connection Settings
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=Broker-Demo
# MT5_PATH="C:\Program Files\MetaTrader 5\terminal64.exe" # Optional: Path to MT5 executable

# Trading Configuration
SYMBOL=XAUUSD

# Safety and Execution Mode
DRY_RUN=True
ALLOW_LIVE_TRADING=False
IS_DEMO_ACCOUNT=True
MIN_EQUITY=100.0
SHADOW_MODE=False
REQUIRE_STOP_LOSS=True
REQUIRE_TAKE_PROFIT=True
MAX_OPEN_POSITIONS=1

# Risk Guards
RISK_PER_TRADE_PCT=0.01
MAX_DAILY_LOSS_PCT=0.05
MAX_DRAWDOWN_PCT=0.15
MAX_CONSECUTIVE_LOSSES=5
MAX_SPREAD_POINTS=50
MAX_SLIPPAGE_POINTS=20
MAX_TRADES_PER_DAY=5

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Database
DATABASE_URL=sqlite:///trades.db

# AI Thresholds
AI_REVIEW_THRESHOLD=60
EXECUTION_THRESHOLD=75
MIN_AI_CONFIDENCE=80

# Startup Safety
# When True, a mismatch between the local ledger and broker positions at startup
# halts trading and trips the kill switch for manual review. Default False keeps
# the auto-sync-and-resume behaviour.
HALT_ON_RECONCILE_MISMATCH=False

# Learning / stats windows (0 or unset = sensible default)
GQOS_BUDGET_LOOKBACK_DAYS=0      # portfolio budget P&L window; 0 = today only
GQOS_SESSION_LOOKBACK_DAYS=30    # session win-rate history window (days)

# Live Guard / recovery probe
LIVE_GUARD_ENTRY_ACTION=PROBE    # PROBE | BLOCK | ALLOW
LIVE_GUARD_PROBE_MULTIPLIER=0.10 # size multiplier while probing a recovering symbol
ENABLE_AUTO_RELAX_PROBE=True     # let recovery readiness scale the probe multiplier

# Exposure normalization multipliers per asset class (advanced; defaults in code)
# GQOS_EXPOSURE_MULTIPLIER_FOREX=1.0
# GQOS_EXPOSURE_MULTIPLIER_METALS=0.35
# GQOS_EXPOSURE_MULTIPLIER_INDICES=0.25
# GQOS_EXPOSURE_MULTIPLIER_CRYPTO=0.20

# Trade throttle (rolling 1h windows)
TRADE_THROTTLE_MAX_GLOBAL_PER_HOUR=5
TRADE_THROTTLE_MAX_SYMBOL_PER_HOUR=2

# Learning data paths (override for tests / alternate deployments)
# GQOS_OUTCOMES_PATH=data/learning/live_outcomes.jsonl
# GQOS_PENDING_TRADES_PATH=data/learning/pending_trades.json

# Position hygiene
AUTO_CLOSE_DISABLED_SYMBOLS=False  # close open positions whose symbol was disabled
MAX_POSITION_AGE_HOURS=0           # close positions older than N hours (0=off)
POSITION_CAPACITY_ALERT_PCT=0.9    # alert when open positions reach this fraction of max
DYNAMIC_DD_DERISK_PCT=0.05   # start halving size at 5% drawdown from peak
DYNAMIC_DD_HALT_PCT=0.20     # hard-stop only at 20% drawdown (was a 10% deadlock)
PATTERN_PF_CEILING=1.5       # reject overfit patterns (backtest PF >= 1.5); 0 = off
# Intraday momentum: trade with trend, close daily
PA_H4_TREND_CONFLICT_ACTION=REJECT      # reject counter-H4-trend trades (momentum edge)
ENABLE_PA_FILTER_AUTOCALIBRATION=False   # don't let calibrator (trained on losses) override
DAILY_FLAT_CLOSE_HOUR_UTC=20             # flat-close + stop entries at 20:00 UTC (-1=off)
