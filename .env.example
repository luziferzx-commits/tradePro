SHADOW_MODE=False

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Database
DATABASE_URL=sqlite:///trades.db

# AI Thresholds
AI_REVIEW_THRESHOLD=60
EXECUTION_THRESHOLD=75
MIN_AI_CONFIDENCE=80
